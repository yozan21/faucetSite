model Cashback {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt
  amount      Decimal     @default(0) @db.Decimal(18, 8)
  status      BonusStatus @default(pending)
  slToken     String?
  nextClaim   DateTime?
  completedAt DateTime?
  active      Boolean     @default(true)
