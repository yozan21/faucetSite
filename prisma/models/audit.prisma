// Immutable audit log — never updated, never deleted
model AuditLog {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt? // null for system/control actions
  teamMemberId BigInt? // if action done by control team
  action       String // LOGIN, CLAIM, PAYOUT_APPROVE, BAN_USER, CONFIG_CHANGE etc
  targetId     String? // id of affected record
  targetType   String? // "User", "WithdrawRequest", etc
  metadata     Json // ip, userAgent, old/new values, anything relevant
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([teamMemberId])
  @@index([action])
  @@index([createdAt])
  @@schema("users_log")
}
