model Shortlink {
  slSessionId String          @id
  userId      BigInt
  source      String?
  sourceId    String?
  amount      Decimal         @default(0) @db.Decimal(18, 8)
  claimToken  String?
  slUrl       String?
  generatedAt DateTime?
  status      ShortlinkStatus @default(pending)
  completedAt DateTime?
  expiredAt   DateTime?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([source, sourceId])
  @@schema("users")
}

model Turnstile {
  id          String    @id
  userId      BigInt
  token       String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  expiredAt   DateTime?

  @@index([userId])
  @@index([token])
  @@schema("users")
}

model SocialTask {
  sessionId String    @id
  userId    BigInt
  url       String?
  duration  Int?
  usable    Boolean   @default(true)
  startTime DateTime?
  endTime   DateTime?
  status    String    @default("pending")
  bonus     Decimal   @default(0) @db.Decimal(18, 8)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@schema("users")
}
