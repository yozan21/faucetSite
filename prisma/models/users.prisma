model User {
  id                     BigInt    @id @default(autoincrement())
  username               String    @unique
  email                  String?   @unique
  password               String
  role                   Role      @default(user)
  isActive               Boolean   @default(true)
  isVerified             Boolean   @default(false)
  isBanned               Boolean   @default(false)
  banReason              String?
  referralCode           String?   @unique
  createdIp              String?   @db.Inet
  createdCountry         String?
  browser                String?
  verifiedAt             DateTime?
  lastUsernameChangeAt   DateTime?
  lastEmailChangeAt      DateTime?
  lastPasswordChangeAt   DateTime?
  recoveryToken          String?
  recoveryTokenVersion   Int       @default(0)
  recoveryTokenCreatedAt DateTime?
  recoveryTokenUsedAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  // relations
  wallet           Wallet?
  loginHistory     LoginHistory[]
  miningHistory    MiningHistory[]
  activeMining     ActiveMining[]
  referralsMade    ReferralUserData[]   @relation("ReferrerRelation")
  referredBy       ReferralUserData?    @relation("ReferredRelation")
  shortlinks       Shortlink[]
  withdrawRequests WithdrawRequest[]
  subscriptions    ActiveSubscription[]
  dailyBonuses     DailyBonus[]
  monthlyBonuses   MonthlyBonus[]
  cashbacks        Cashback[]
  history          History[]
  boostsPurchased  BoostPurchased[]
  transactions     TransactionLog[]

  @@index([username])
  @@index([email])
  @@index([referralCode])
  @@schema("users")
}

model LoginHistory {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt? // nullable — failed login might be unknown username
  identifier    String   @default("test") // what they typed (username or email)
  success       Boolean  @default(false)
  failureReason String? // INVALID_PASSWORD, BANNED, INACTIVE, COUNTRY_MISMATCH etc
  loginIp       String?  @db.Inet
  loginCountry  String?
  browser       String?
  loginAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([identifier])
  @@index([loginIp])
  @@schema("users")
}
