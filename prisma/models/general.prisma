model WithdrawPool {
  id           BigInt    @id @default(autoincrement())
  coinName     String
  symbol       String    @unique
  type         String    @default("")
  minWithdraw  Decimal   @default(0) @db.Decimal(18, 8)
  poolBalance  Decimal   @default(0) @db.Decimal(18, 8)
  poolCapacity Decimal   @default(0) @db.Decimal(18, 8)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@schema("general")
}

model WithdrawRequest {
  requestNo       String       @id
  userId          BigInt
  coinName        String
  coinAmount      Decimal      @default(0) @db.Decimal(18, 8)
  type            String?
  walletAddress   String
  feePercentage   Decimal      @default(0) @db.Decimal(9, 6)
  feeAmount       Decimal      @default(0) @db.Decimal(18, 8)
  estimatedAmount Decimal      @default(0) @db.Decimal(18, 8)
  status          PayoutStatus @default(pending)
  txid            String?
  processedById   BigInt? // TeamMember id
  processedAt     DateTime?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([coinName])
  @@schema("users")
}

model PowerBoost {
  id            BigInt    @id @default(autoincrement())
  tierName      String
  bonusPercent  Decimal   @default(0) @db.Decimal(7, 4)
  durationHours Int       @default(0)
  rate          Decimal?  @db.Decimal(18, 8)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@schema("general")
}

model Banner {
  id         BigInt    @id @default(autoincrement())
  title      String
  url        String?
  imgUrl     String
  alt        String
  deviceType String?
  position   String
  active     Boolean   @default(true)
  createdBy  String?
  controlId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([active])
  @@index([position])
  @@schema("general")
}

model LatestUpdate {
  id            BigInt    @id @default(autoincrement())
  title         String
  description   String?
  publishedDate DateTime?
  isActive      Boolean   @default(true)
  createdBy     String?
  controlId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@schema("general")
}

model Video {
  id        BigInt    @id @default(autoincrement())
  url       String    @unique
  duration  Int
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@schema("general")
}

model Link {
  id        BigInt    @id @default(autoincrement())
  title     String
  detail    String?
  url       String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([title])
  @@schema("general")
}

model ReferralLevel {
  id              BigInt    @id @default(autoincrement())
  levelName       String
  progressPercent Decimal   @default(0) @db.Decimal(7, 4)
  description     String?
  iconName        String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@schema("general")
}

model EarlyAccess {
  id                  BigInt            @id @default(autoincrement())
  email               String            @unique
  status              EarlyAccessStatus @default(disallowed)
  inviteCode          String?           @unique
  inviteCodeExpiresAt DateTime?
  allowedAt           DateTime?
  allowedById         BigInt? // TeamMember id
  disallowedAt        DateTime?
  disallowedById      BigInt? // TeamMember id
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([inviteCode])
  @@index([email])
  @@schema("general")
}
