model Subscription {
  id           BigInt    @id @default(autoincrement())
  name         String
  slug         String    @unique
  monthlyPrice Decimal?  @db.Decimal(18, 8)
  annualPrice  Decimal?  @db.Decimal(18, 8)
  description  String?
  featured     Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  features SubscriptionFeature[]

  @@schema("general")
}

model SubscriptionFeature {
  id               BigInt    @id @default(autoincrement())
  subscriptionSlug String
  featureText      String
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  subscription Subscription @relation(fields: [subscriptionSlug], references: [slug], onDelete: Restrict)

  @@index([subscriptionSlug])
  @@schema("general")
}

model SubscriptionPurchased {
  sessionId        String    @id
  userId           BigInt
  amount           Decimal   @default(0) @db.Decimal(18, 8)
  subscriptionName String?
  depositId        String?
  address          String?
  coinName         String?
  type             String?
  network          String?
  rate             Decimal?  @db.Decimal(18, 8)
  cryptoValue      Decimal?  @db.Decimal(18, 8)
  usdAmount        Decimal?  @db.Decimal(18, 8)
  createdDate      DateTime?
  expectedDate     DateTime?
  completedDate    DateTime?
  expireAt         DateTime?
  status           String    @default("pending")
  txid             String?
  verifiedTxid     String?
  isActive         Boolean   @default(true)

  @@index([userId])
  @@index([depositId])
  @@schema("users")
}

model ActiveSubscription {
  id               BigInt             @id @default(autoincrement())
  userId           BigInt
  subscriptionName String
  sourceId         String             @unique
  status           SubscriptionStatus @default(active)
  active           Boolean            @default(true)
  expireAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@schema("users")
}
