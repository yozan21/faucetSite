model ActiveMining {
  miningSessionId String    @id
  userId          BigInt
  coinName        String
  startTime       DateTime?
  stopTime        DateTime?
  expiryTime      DateTime?
  durationLeft    Int?
  amountMined     Decimal   @default(0) @db.Decimal(18, 8)
  bonus           Decimal   @default(0) @db.Decimal(18, 8)
  socialTaskId    String?
  powerBoostId    String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([coinName])
  @@schema("users")
}

model MiningHistory {
  id                  BigInt       @id @default(autoincrement())
  miningSessionId     String?
  userId              BigInt
  coinName            String
  startTime           DateTime?
  stopTime            DateTime?
  expiryTime          DateTime?
  amountMined         Decimal      @default(0) @db.Decimal(18, 8)
  bonusAmount         Decimal      @default(0) @db.Decimal(18, 8)
  totalAmount         Decimal      @default(0) @db.Decimal(18, 8)
  bonusPercent        Decimal      @default(0) @db.Decimal(7, 4)
  status              MiningStatus @default(active)
  claimableExpiryTime DateTime?
  slToken             String?
  balanceBefore       Decimal?     @db.Decimal(18, 8)
  balanceAfter        Decimal?     @db.Decimal(18, 8)
  socialTaskId        String?
  powerBoostId        String?
  createdAt           DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([miningSessionId])
  @@index([coinName])
  @@schema("users")
}
